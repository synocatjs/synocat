{
  "name": "synocat",
  "version": "1.0.0",
  "description": "CLI scaffold tool for Synology DSM 7 packages — designed for frontend developers",
  "main": "dist/cli/index.js",
  "bin": {
    "synocat": "dist/cli/index.js",
    "synopkg": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "dev": "ts-node src/cli/index.ts",
    "clean": "rm -rf dist",
    "prebuild": "pnpm clean",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "synology",
    "dsm",
    "spk",
    "nas",
    "package",
    "scaffold",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@types/inquirer": "^9.0.9",
    "archiver": "^6.0.1",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.2.12",
    "ora": "^7.0.1",
    "sharp": "^0.34.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.5.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}